# Pre-funded demo bank wallet for Auton agent demos.
# Without this, the app falls back to the devnet/testnet faucet,
# which is rate-limited and will fail after a few runs.
#
# Setup (one-time):
#
# 1. Generate a keypair:
#    node -e "
#      const {Keypair} = require('@solana/web3.js');
#      const k = Keypair.generate();
#      console.log('Address:', k.publicKey.toString());
#      console.log('Secret:', JSON.stringify(Array.from(k.secretKey)));
#    "
#
# 2. Copy the Address and fund it with devnet SOL at:
#    https://faucet.solana.com  (request 1-2 SOL, network: devnet)
#
# 3. Paste the Secret array below:

DEMO_BANK_SECRET=[0,0,0,0,...]
